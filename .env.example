# ============================================================
#  Variables de entorno - Hotel Ecka
#  Copia este archivo como ".env.local" para desarrollo local.
#  En Vercel: Project Settings -> Environment Variables.
# ============================================================

# --- Conexion a MySQL ---
# El driver usa DATABASE_URL si existe; si no, usa las variables MYSQL_*.
#
# (A) XAMPP local (root sin contrasenia, base "hoteldb"):
DATABASE_URL="mysql://root@localhost:3306/hoteldb"
#
# (B) Railway: copia la "Connection URL" del servicio MySQL, p. ej.:
# DATABASE_URL="mysql://root:CONTRASENIA@containers-us-west-x.railway.app:6543/railway"

# --- Alternativa: variables sueltas (solo se usan si NO defines DATABASE_URL) ---
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DATABASE="hoteldb"

# --- Credenciales de acceso a la aplicacion (login) ---
APP_USER="admin"
APP_PASSWORD="ecka2026"

# --- Secreto para firmar la cookie de sesion (cambialo por algo largo y aleatorio) ---
SESSION_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
